# 本地开发配置模板。
# 用法：复制本文件为 application-dev.yml，填入你自己的本地账号密码。
# application-dev.yml 已被 .gitignore，不会进版本库。
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/kyonelife?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: root
    password: <your-mysql-password>
  data:
    redis:
      host: localhost
      port: 6379
      password: <your-redis-password>

minio:
  endpoint: http://localhost:9000
  public-endpoint: http://localhost:9000
  access-key: <your-minio-access-key>
  secret-key: <your-minio-secret-key>

# AI 大模型 Key（也可改用环境变量 DEEPSEEK_API_KEY）。未配置则 AI 接口自动降级。
spring:
  ai:
    deepseek:
      api-key: <your-deepseek-api-key>
