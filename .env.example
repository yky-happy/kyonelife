# 生产环境变量模板（docker-compose / 服务器用）。
# 用法：复制为 .env 并填入真实值；.env 已 gitignore，不进版本库。
# 启动时设置 SPRING_PROFILES_ACTIVE=prod，应用即从这些变量读取连接信息。

SPRING_PROFILES_ACTIVE=prod

# ---- 域名（网关按此路由 + 生成 nginx 配置）----
# 读者端主域名 与 后台子域名，两者都要解析到本服务器公网 IP。
DOMAIN=your-domain.com
ADMIN_DOMAIN=admin.your-domain.com

# ---- MySQL ----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=kyonelife
MYSQL_USER=root
MYSQL_PASSWORD=change-me-mysql-root-password

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# ---- MinIO ----
MINIO_ENDPOINT=http://minio:9000
# 浏览器可访问的公网地址：生产走网关反代，填 https://主域名/minio
# （网关 location /minio/ 会剥掉前缀转发给 MinIO；本地演示才填 http://localhost:9000）
MINIO_PUBLIC_ENDPOINT=https://your-domain.com/minio
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=kyonelife

# ---- CORS 允许的前端域名（逗号分隔）----
# 前后端已同源（都在同一域名下经网关访问），CORS 基本用不到；
# 仍显式列出主域名与后台子域名以防万一。
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ---- 邮箱验证码（QQ 邮箱 SMTP）----
# username 填 QQ 邮箱；password 填 QQ 邮箱「授权码」(在 QQ 邮箱设置→账号里开启 SMTP 后获取)，不是登录密码。
# 不填则应用仍能启动，只是注册/找回密码的邮件验证码发不出去。
MAIL_USERNAME=your-qq@qq.com
MAIL_PASSWORD=your-qq-smtp-auth-code

# ---- AI（Spring AI + DeepSeek，用于摘要生成 / 标签推荐）----
# 在 https://platform.deepseek.com 申请 API Key；未配置时 AI 接口自动降级，不影响其他功能。
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
